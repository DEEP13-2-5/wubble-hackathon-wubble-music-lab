PORT=4000
FRONTEND_ORIGIN=http://localhost:4000
MONGODB_URI=mongodb://127.0.0.1:27017/music_app

# Add your Wubble API settings here.
WUBBLE_API_BASE_URL=https://api.wubble.ai
WUBBLE_API_KEY=YOUR_KEY_HERE
WUBBLE_GENERATE_ENDPOINT=/api/v1/chat
WUBBLE_POLL_ENDPOINT=/api/v1/polling/{requestId}
WUBBLE_UPLOAD_ENDPOINT=/api/v1/upload
WUBBLE_POLL_LIMIT=20
WUBBLE_POLL_DELAY_MS=3000
